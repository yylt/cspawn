# Worker service example - Worker 工作进程示例

[Unit]
Description=Background Worker in cspawn
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/cspawn -f /etc/cspawn/worker.yaml /usr/bin/python3 /app/worker.py
Restart=always
RestartSec=3

# 环境变量 (可以通过配置文件设置)
EnvironmentFile=-/etc/cspawn/worker.env

# 资源限制
MemoryMax=512M
CPUQuota=50%

# 日志
StandardOutput=journal
StandardError=journal
SyslogIdentifier=cspawn-worker

[Install]
WantedBy=multi-user.target
